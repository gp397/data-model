{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$defs": {
    "Teacher": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^T-[0-9]{3}$"},
        "name": {"type": "string"},
        "email": {"type": "string", "pattern": "^[^@]+@[^@]+\\.[^@]+$"}
      },
      "required": ["id", "name", "email"]
    },
    "Student": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^S-[0-9]{4}$"},
        "name": {"type": "string"},
        "year": {"type": "integer", "minimum": 1, "maximum": 6}
      },
      "required": ["id", "name", "year"]
    },
    "Course": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^C-[A-Z]{3}-[0-9]{3}$"},
        "title": {"type": "string"},
        "room": {"type": "string", "pattern": "^R-[0-9]{2}$"},
        "teacher_id": {"type": "string", "pattern": "^T-[0-9]{3}$"},
        "student_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "pattern": "^S-[0-9]{4}$"}
        }
      },
      "required": ["id", "title", "room", "teacher_id", "student_ids"]
    }
  }
}
